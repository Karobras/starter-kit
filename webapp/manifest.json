 <!---dodanie w routes i targets -->


{
  "_version": "1.70.1",
  "sap.app": {
    "id": "stk.starterkit",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
   "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.26.0",
      "toolsId": "8648ea4f-9b84-4ef4-a3dd-c6a4b1622eae"
    },
    "dataSources": {
      "mainService": {
        "uri": "/V2/Northwind/Northwind.svc/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.133.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
     
 
      "": {
         "type": "sap.ui.model.odata.v2.ODataModel",
        "dataSource": "mainService",
        "preload": true,
        "settings": {
"defaultBindingMode": "TwoWay",
"defaultCountMode": "Inline",
"refreshAfterChange": true,
"useBatch": false
 
        }
      },
 
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "stk.starterkit.i18n.i18n"
        }
      },
 
 
      "CustomersProperties": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "stk.starterkit.view",
        "async": true,
        "viewPath": "stk.starterkit.view",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "CustomersList",
          "pattern": "",
          "target": [
            "CustomersList"
          ]
        },
        {
          "name": "CustomerDetails",
          "pattern": "CustomerDetails/{CustomerID}",
          "target": [
            "CustomerDetails"
          ]
        },
        {
          "name": "CreateCustomer",
          "pattern": "CreateCustomer",
          "target": [
            "CreateCustomer"
          ]
        },
        {
          "name": "Performance",
          "pattern": "Performance",
          "target": [
            "Performance"
          ]
        }
      ],
      "targets": {
                      "CustomerDetails": {
          "viewType": "XML",
          "viewName": "CustomerDetails"
      },
                "CustomersList": {
          "viewType": "XML",
          "viewName": "CustomersList"
      },
                  "CreateCustomer": {
          "viewType": "XML",
          "viewName": "CreateCustomer"
      },
                  "Performance": {
          "viewType": "XML",
          "viewName": "Performance" }
 
 
      }
    },
    "rootView": {
      "viewName": "stk.starterkit.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
