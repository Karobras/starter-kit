<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" 
 controllerName="stk.starterkit.controller.CustomerDetails" displayBlock="true">
            <Page xmlns:cd="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" id="CustomerDetails" title="{CustomerID}"
            showNavButton="true" navButtonPress="handleNavButtonPress">
    
 <Table items= "CustomerID"  id="customerTable3"> 
    <columns>
    <Column id="companyNameColumn1">
    <Label text="{i18n>CompanyName}" id="companyNameLabel3"/>
    </Column>
        <Column id="buttonColumn">
    </Column>
    </columns>
    <items>
    <ColumnListItem id="CustomerListItem3"  >  
    <Text text="{CompanyName}" id="companyNameText5"/>
    <Button id="Info"  press="_onDetailsInfo" text="Show contact Info"/>
    </ColumnListItem>
    </items>
    </Table>
 <Table items= "{Orders}" id="customerTable2"> 
    <columns>
    <Column id="companyNameColumn2">
    <Label text="{i18n>ShipCountry}" id="companyNameLabel2"/>
    </Column>
    <Column id="countryColumn2">
    <Label text="{i18n>OrderID}" id="countryLabel2"/>
    </Column>
      <Column id= "customerIdColumn2">
    <Label text="{i18n>ShipName}" id="customerIdLabel2"/>
    </Column>
        <Column id= "employeeColumn">
    <Label text="{i18n>FirstName}" id="employeeLabel"/>
      </Column>
    <Column id="OrderDateColumn">
    <Label text="{i18n>OrderDate}" id="orderDateLabel"/>
    </Column>
    </columns>
    <items>
    <ColumnListItem id="CustomerListItem2" > 
    <Text text="{ShipName}" id="companyNameText3"/>
    <!-- <Text text="{Country}" id="countryText"/> -->
    <Text text="{OrderID}" id="customerIdText2"/>
    <Text id="companyNameText4" text ="{= ${ShipCountry} === 'USA' ? 'United States of America' : (${ShipCountry} === 'UK' ? 'United Kingdom' : ${ShipCountry}) }" />
       <Text text="{ parts: [{ path: 'Employee/FirstName' }, { path: 'Employee/LastName' }], formatter: '.Formatter.formatName' }" />
       <Text text="{path: 'OrderDate', type: 'sap.ui.model.type.DateTime', formatOptions: {style: 'medium'}}" id="orderDateText"/>    
    </ColumnListItem>
    </items>
    </Table>

            </Page>
</mvc:View>
